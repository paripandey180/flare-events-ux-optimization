{% comment %}
Added by Vamika
Updated: Auto-play muted video section for Shopify
{% endcomment %}

<section class="auto-video-section-{{ section.id }}">
  <div class="auto-video-section__inner">
    {% if section.settings.video != blank %}
      <div class="auto-video-section__media">
        {{
          section.settings.video
          | video_tag:
            autoplay: true,
            loop: true,
            controls: false,
            muted: true,
            playsinline: true,
            preload: 'metadata',
            class: 'auto-video-section__video'
        }}
      </div>
    {% else %}
      <div class="auto-video-section__placeholder">
        <p>Add a video in the theme editor to display it here.</p>
      </div>
    {% endif %}

    {% if section.settings.heading != blank or section.settings.subtext != blank or section.settings.button_label != blank %}
      <div class="auto-video-section__overlay auto-video-section__overlay--{{ section.settings.content_position }}">
        <div class="auto-video-section__content">
          {% if section.settings.heading != blank %}
            <h2 class="auto-video-section__heading">{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.subtext != blank %}
            <div class="auto-video-section__subtext">{{ section.settings.subtext }}</div>
          {% endif %}

          {% if section.settings.button_label != blank and section.settings.button_link != blank %}
            <a href="{{ section.settings.button_link }}" class="auto-video-section__button">
              {{ section.settings.button_label }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .auto-video-section-{{ section.id }} {
    width: 100%;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__inner {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #000;
    min-height: {{ section.settings.section_height }}px;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__media {
    position: relative;
    width: 100%;
    height: {{ section.settings.section_height }}px;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__video {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.video_fit }};
    display: block;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__media video {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.video_fit }};
    display: block;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__placeholder {
    height: {{ section.settings.section_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111;
    color: #fff;
    text-align: center;
    padding: 20px;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    padding: 40px;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | times: 0.01 }});
    pointer-events: none;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--top-left {
    justify-content: flex-start;
    align-items: flex-start;
    text-align: left;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--top-center {
    justify-content: center;
    align-items: flex-start;
    text-align: center;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--top-right {
    justify-content: flex-end;
    align-items: flex-start;
    text-align: right;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--middle-left {
    justify-content: flex-start;
    align-items: center;
    text-align: left;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--center {
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--middle-right {
    justify-content: flex-end;
    align-items: center;
    text-align: right;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--bottom-left {
    justify-content: flex-start;
    align-items: flex-end;
    text-align: left;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--bottom-center {
    justify-content: center;
    align-items: flex-end;
    text-align: center;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__overlay--bottom-right {
    justify-content: flex-end;
    align-items: flex-end;
    text-align: right;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__content {
    max-width: 700px;
    color: {{ section.settings.text_color }};
    pointer-events: auto;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__heading {
    margin: 0 0 12px;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    color: {{ section.settings.text_color }};
  }

  .auto-video-section-{{ section.id }} .auto-video-section__subtext {
    margin: 0 0 20px;
    font-size: {{ section.settings.subtext_size }}px;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
  }

  .auto-video-section-{{ section.id }} .auto-video-section__button {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    border-radius: 999px;
    font-size: 16px;
    transition: opacity 0.2s ease;
  }

  .auto-video-section-{{ section.id }} .auto-video-section__button:hover {
    opacity: 0.88;
  }

  @media screen and (max-width: 749px) {
    .auto-video-section-{{ section.id }} .auto-video-section__inner,
    .auto-video-section-{{ section.id }} .auto-video-section__media,
    .auto-video-section-{{ section.id }} .auto-video-section__placeholder {
      min-height: {{ section.settings.mobile_height }}px;
      height: {{ section.settings.mobile_height }}px;
    }

    .auto-video-section-{{ section.id }} .auto-video-section__overlay {
      padding: 24px 20px;
    }

    .auto-video-section-{{ section.id }} .auto-video-section__heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    .auto-video-section-{{ section.id }} .auto-video-section__subtext {
      font-size: {{ section.settings.mobile_subtext_size }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Auto Play Video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop height",
      "min": 300,
      "max": 1000,
      "step": 20,
      "default": 700,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 250,
      "max": 800,
      "step": 10,
      "default": 500,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "video_fit",
      "label": "Video fit",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your heading here"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Add supporting text here.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Desktop heading size",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Desktop subtext size",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Mobile heading size",
      "min": 20,
      "max": 50,
      "step": 2,
      "default": 34,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_subtext_size",
      "label": "Mobile subtext size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "default": "center",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "middle-left", "label": "Middle left" },
        { "value": "center", "label": "Center" },
        { "value": "middle-right", "label": "Middle right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 20,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Auto Play Video"
    }
  ]
}
{% endschema %}

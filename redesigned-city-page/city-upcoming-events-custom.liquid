        },
        {
          "type": "text",
          "id": "accessibility_features",
          "label": "Accessibility Features",
          "default": "Venue accessibility available."
        },
        {
          "type": "text",
          "id": "dress_code",
          "label": "Dress Code",
          "default": "Dress to impress."
        },
        {
          "type": "text",
          "id": "event_format",
          "label": "Event Format",
          "default": "Icebreaker game followed by 8-minute speed dating rounds."
        },
        {
          "type": "text",
          "id": "parking_transportation",
          "label": "Parking / Transportation",
          "default": "Street parking and nearby transit options available."
        },
        {
          "type": "text",
          "id": "host_information",
          "label": "Host Information",
          "default": "Hosted by Flare Events."
        },
        {
          "type": "text",
          "id": "event_type",
          "label": "Event Type",
          "default": "In-person speed dating"
        },
        {
          "type": "text",
          "id": "gender_ratio_capacity",
          "label": "Gender Ratio / Capacity"
        },
        {
          "type": "text",
          "id": "refund_policy",
          "label": "Refund Policy",
          "default": "No refunds."
        }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "Upcoming events",
      "blocks": [
        {
          "type": "event"
        },
        {
          "type": "event"
        },
        {
          "type": "event"
        }
      ]

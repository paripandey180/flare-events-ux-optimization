    {
      "type": "text",
      "id": "subtext_2",
      "label": "Subtext line 2",
      "default": "Over 10,000 conversations started in Toronto"
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Event image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "New!"
        },
        {

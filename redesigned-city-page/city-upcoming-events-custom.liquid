        },
        {
          "type": "text",
          "id": "venue",
          "label": "Venue",
          "default": "The Alembic Stillhouse – 180 Cooper Street, Ottawa"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event title",
          "default": "Straight Speed Dating"
        },
        {
          "type": "text",
          "id": "age_range",
          "label": "Age range",
          "default": "Ages 34 - 43"
        },
        {
          "type": "text",
          "id": "early_bird_price",
          "label": "Early bird price",
          "default": "Early Bird Admission | $40"
        },
        {
          "type": "text",
          "id": "regular_price",
          "label": "Regular price",
          "default": "Regular Admission | $45"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Book Your Spot"
        },
        {
          "type": "url",

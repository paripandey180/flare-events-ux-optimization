{% comment %}
  Shopify Section: Testimonials Carousel
  Save as: sections/testimonials-carousel.liquid
{% endcomment %}

<section id="shopify-section-{{ section.id }}" class="flare-testimonials">
  <div class="flare-testimonials__container">
    {% if section.settings.heading != blank %}
      <h2 class="flare-testimonials__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <div class="flare-testimonials__subheading">{{ section.settings.subheading }}</div>
    {% endif %}

    <div class="flare-testimonials__carousel-wrapper">
      <button
        type="button"
        class="flare-testimonials__nav flare-testimonials__nav--prev"
        aria-label="Previous testimonial"
      >
        <span>&larr;</span>
      </button>

      <div class="flare-testimonials__viewport" data-carousel-viewport>
        <div class="flare-testimonials__track" data-carousel-track>
          {% for block in section.blocks %}
            <article class="flare-testimonials__card" {{ block.shopify_attributes }}>
              <div class="flare-testimonials__card-top">
                <div class="flare-testimonials__avatar-wrap">
                  {% if block.settings.avatar != blank %}
                    {{ block.settings.avatar | image_url: width: 120 | image_tag:
                      class: 'flare-testimonials__avatar',
                      loading: 'lazy',
                      widths: '60, 90, 120',
                      alt: block.settings.name
                    }}
                  {% else %}
                    <div class="flare-testimonials__avatar flare-testimonials__avatar--placeholder">
                      {{ block.settings.name | slice: 0 }}
                    </div>
                  {% endif %}
                </div>

                <div class="flare-testimonials__meta">
                  <h3 class="flare-testimonials__name">{{ block.settings.name }}</h3>
                  <div class="flare-testimonials__location">{{ block.settings.location }}</div>
                </div>
              </div>

              <div class="flare-testimonials__stars" aria-label="{{ block.settings.stars }} star review">
                {% for i in (1..5) %}
                  <span class="flare-testimonials__star {% if i <= block.settings.stars %}is-filled{% endif %}">★</span>
                {% endfor %}
              </div>

              {% if block.settings.quote != blank %}
                <div class="flare-testimonials__quote">{{ block.settings.quote }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </div>

      <button
        type="button"
        class="flare-testimonials__nav flare-testimonials__nav--next"
        aria-label="Next testimonial"
      >
        <span>&rarr;</span>
      </button>
    </div>

    <div class="flare-testimonials__footer">
      <a class="flare-testimonials__link flare-testimonials__link--left" href="{{ section.settings.left_link_url }}">
        {{ section.settings.left_link_text }}
      </a>

      <a class="flare-testimonials__link flare-testimonials__link--right" href="{{ section.settings.right_link_url }}">
        {{ section.settings.right_link_text }}
      </a>
    </div>
  </div>

  <style>
    #shopify-section-{{ section.id }} {
      background: #000000;
      color: #ffffff;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__container {
      max-width: 1600px;
      margin: 0 auto;
      padding: 72px 20px 32px;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__heading {
      margin: 0;
      text-align: center;
      font-size: clamp(34px, 4vw, 64px);
      line-height: 1.05;
      font-weight: 500;
      color: {{ section.settings.heading_color }};
      letter-spacing: -0.02em;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__subheading {
      text-align: center;
      margin-top: 10px;
      font-size: clamp(18px, 1.5vw, 33px);
      line-height: 1.3;
      color: rgba(255, 255, 255, 0.92);
      font-weight: 400;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__carousel-wrapper {
      position: relative;
      margin-top: 56px;
      padding: 0 54px;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__viewport {
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__track {
      display: flex;
      gap: 28px;
      will-change: transform;
      transition: transform 500ms ease;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__card {
      flex: 0 0 calc((100% - 56px) / 3);
      min-height: 275px;
      background: linear-gradient(180deg, #08162f 0%, #071327 100%);
      border-radius: 12px;
      box-shadow: 8px 0 0 rgba(0, 0, 0, 0.32);
      padding: 30px 32px 28px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__card-top {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__avatar-wrap {
      flex: 0 0 auto;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__avatar {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      background: #d9d9d9;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__avatar--placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #ffffff;
      background: #6a40d8;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__name {
      margin: 0;
      font-size: 18px;
      line-height: 1.1;
      font-weight: 700;
      color: #ffffff;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__location {
      margin-top: 4px;
      font-size: 16px;
      line-height: 1.2;
      color: rgba(255, 255, 255, 0.72);
    }

    #shopify-section-{{ section.id }} .flare-testimonials__stars {
      display: flex;
      gap: 3px;
      margin-top: 26px;
      font-size: 24px;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__star {
      color: rgba(214, 177, 66, 0.28);
    }

    #shopify-section-{{ section.id }} .flare-testimonials__star.is-filled {
      color: #d3af43;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__quote {
      margin-top: 22px;
      font-size: clamp(18px, 1.35vw, 22px);
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.9);
    }

    #shopify-section-{{ section.id }} .flare-testimonials__footer {
      margin-top: 22px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 20px;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__link {
      color: #ffffff;
      text-decoration: none;
      font-size: clamp(16px, 1.2vw, 24px);
      line-height: 1.25;
      transition: opacity 0.2s ease;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__link:hover {
      opacity: 0.75;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.04);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 2;
      transition: background 0.2s ease, opacity 0.2s ease;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__nav:hover {
      background: rgba(255, 255, 255, 0.10);
    }

    #shopify-section-{{ section.id }} .flare-testimonials__nav--prev {
      left: 0;
    }

    #shopify-section-{{ section.id }} .flare-testimonials__nav--next {
      right: 0;
    }

    @media screen and (max-width: 1199px) {
      #shopify-section-{{ section.id }} .flare-testimonials__card {
        flex: 0 0 calc((100% - 28px) / 2);
      }
    }

    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} .flare-testimonials__container {
        padding: 48px 16px 24px;
      }

      #shopify-section-{{ section.id }} .flare-testimonials__carousel-wrapper {
        margin-top: 36px;
        padding: 0 42px;
      }

      #shopify-section-{{ section.id }} .flare-testimonials__card {
        flex: 0 0 100%;
        min-height: auto;
        padding: 24px 22px;
      }

      #shopify-section-{{ section.id }} .flare-testimonials__stars {
        margin-top: 18px;
        font-size: 22px;
      }

      #shopify-section-{{ section.id }} .flare-testimonials__quote {
        margin-top: 18px;
        font-size: 18px;
      }

      #shopify-section-{{ section.id }} .flare-testimonials__footer {
        margin-top: 18px;
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>

  <script>
    (() => {
      const root = document.getElementById('shopify-section-{{ section.id }}');
      if (!root) return;

      const viewport = root.querySelector('[data-carousel-viewport]');
      const track = root.querySelector('[data-carousel-track]');
      const prevBtn = root.querySelector('.flare-testimonials__nav--prev');
      const nextBtn = root.querySelector('.flare-testimonials__nav--next');
      const cards = Array.from(root.querySelectorAll('.flare-testimonials__card'));

      if (!viewport || !track || cards.length === 0) return;

      let currentIndex = 0;
      let autoPlay;

      const getCardsPerView = () => {
        if (window.innerWidth <= 767) return 1;
        if (window.innerWidth <= 1199) return 2;
        return 3;
      };

      const maxIndex = () => Math.max(0, cards.length - getCardsPerView());

      const updateCarousel = (animate = true) => {
        const card = cards[0];
        const gap = parseFloat(window.getComputedStyle(track).gap) || 0;
        const offset = currentIndex * (card.offsetWidth + gap);
        track.style.transition = animate ? 'transform 500ms ease' : 'none';
        track.style.transform = `translate3d(-${offset}px, 0, 0)`;
      };

      const nextSlide = () => {
        currentIndex = currentIndex >= maxIndex() ? 0 : currentIndex + 1;
        updateCarousel();
      };

      const prevSlide = () => {
        currentIndex = currentIndex <= 0 ? maxIndex() : currentIndex - 1;
        updateCarousel();
      };

      const startAutoPlay = () => {
        stopAutoPlay();
        autoPlay = window.setInterval(nextSlide, {{ section.settings.autoplay_speed | times: 1000 }});
      };

      const stopAutoPlay = () => {
        if (autoPlay) window.clearInterval(autoPlay);
      };

      nextBtn?.addEventListener('click', () => {
        nextSlide();
        startAutoPlay();
      });

      prevBtn?.addEventListener('click', () => {
        prevSlide();
        startAutoPlay();
      });

      root.addEventListener('mouseenter', stopAutoPlay);
      root.addEventListener('mouseleave', startAutoPlay);
      window.addEventListener('resize', () => {
        currentIndex = Math.min(currentIndex, maxIndex());
        updateCarousel(false);
      });

      updateCarousel(false);

      {% if section.settings.enable_autoplay %}
        startAutoPlay();
      {% endif %}
    })();
  </script>
</section>

{% schema %}
{
  "name": "Testimonials carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Members Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Over 200 success stories"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#c8a03b"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "left_link_url",
      "label": "Left footer link"
    },
    {
      "type": "text",
      "id": "left_link_text",
      "label": "Left footer text",
      "default": "See Photos from Real Flare Events →"
    },
    {
      "type": "url",
      "id": "right_link_url",
      "label": "Right footer link"
    },
    {
      "type": "text",
      "id": "right_link_text",
      "label": "Right footer text",
      "default": "See More Reviews"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Toronto"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I met my boyfriend at a Flare event in Toronto! The atmosphere was so relaxed and genuine. No pressure, just real conversations with amazing people."
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [

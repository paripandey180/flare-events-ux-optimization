{% comment %} Added by Sanika {% endcomment %}

<section class="get-started-steps-v2">
  <div class="page-width get-started-steps-v2__wrapper">
    <div class="get-started-steps-v2__topline">
      {% if section.settings.top_icon %}
        <div class="get-started-steps-v2__flame">
          {{
            section.settings.top_icon
            | image_url: width: 120
            | image_tag: alt: section.settings.tagline, loading: 'lazy'
          }}
        </div>
      {% endif %}
      <p class="get-started-steps-v2__tagline">{{ section.settings.tagline }}</p>
    </div>

    <h2 class="get-started-steps-v2__heading">{{ section.settings.heading }}</h2>

    <div class="get-started-steps-v2__cards">
      {% for block in section.blocks %}
        <div class="get-started-step-card" {{ block.shopify_attributes }}>
          <div class="get-started-step-card__number">{{ forloop.index }}</div>

          {% if block.settings.icon %}
            <div class="get-started-step-card__icon">
              {{
                block.settings.icon
                | image_url: width: 84
                | image_tag: alt: block.settings.title, loading: 'lazy'
              }}
            </div>
          {% endif %}

          <h3 class="get-started-step-card__title">{{ block.settings.title }}</h3>

          <div class="get-started-step-card__description">
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank %}
      <div class="get-started-steps-v2__button-wrap">
        <a href="{{ section.settings.button_link }}" class="get-started-steps-v2__button">
          {{ section.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .get-started-steps-v2 {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    background:
      radial-gradient(circle at top center, rgba(199, 161, 58, 0.08), transparent 30%),
      linear-gradient(180deg, #060606 0%, #090909 100%);
    padding: 65px 0 85px;
  }

  .get-started-steps-v2__wrapper {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .get-started-steps-v2__topline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
    text-align: center;
    margin-bottom: 18px;
  }

  .get-started-steps-v2__flame {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .get-started-steps-v2__flame img {
    width: 64px;
    height: auto;
    display: block;
  }


  .get-started-steps-v2__tagline {
    margin: 0;
    color: #e0b830;

    font-family: var(--font-body-family);
    font-style: var(--font-body-style);

    font-size: 42px;   
    line-height: 1.15;
    font-weight: 700;  
    letter-spacing: -0.02em; 

    text-align: center;
}

  .get-started-steps-v2__heading {
    margin: 0 0 68px;
    text-align: center;
    color: #ffffff;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 33px;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .get-started-steps-v2__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(280px, 1fr));
    gap: 34px;
    align-items: stretch;
    margin-bottom: 64px;
  }

  .get-started-step-card {
    position: relative;
    background:
      linear-gradient(180deg, rgba(10, 21, 41, 0.98) 0%, rgba(7, 16, 33, 0.98) 100%);
    border: 1px solid rgba(199, 161, 58, 0.25);
    border-radius: 24px;
    padding: 34px 28px 30px;
    min-height: 270px;
    text-align: center;
    box-shadow:
      0 18px 45px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
  }

  .get-started-step-card:hover {
    transform: translateY(-4px);
    border-color: rgba(199, 161, 58, 0.5);
    box-shadow:
      0 22px 55px rgba(0, 0, 0, 0.36),
      0 0 24px rgba(199, 161, 58, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .get-started-step-card__number {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1.5px solid #e0b830;
    color: #e0b830;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 14px;
    line-height: 1;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.18);
  }

  .get-started-step-card__icon {
    width: 78px;
    height: 78px;
    border-radius: 999px;
    background: linear-gradient(180deg, #e2c24f 0%, #e0b830 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 22px;
    box-shadow: 0 10px 24px rgba(199, 161, 58, 0.22);
    overflow: hidden;
  }

  .get-started-step-card__icon img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    display: block;
  }

  .get-started-step-card__title {
    margin: 0 0 14px;
    color: #e0b830;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 21px;
    line-height: 1.25;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .get-started-step-card__description p {
    margin: 0;
    color: #ececec;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 16px;
    line-height: 1.6;
    max-width: 250px;
    margin-left: auto;
    margin-right: auto;
  }

  .get-started-steps-v2__button-wrap {
    display: flex;
    justify-content: center;
  }

  .get-started-steps-v2__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 250px;
    padding: 18px 38px;
    border-radius: 999px;
    background: linear-gradient(180deg, #e0b830 0%, #e0b830 100%);
    color: #0a0a0a;
    text-decoration: none;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 20px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -0.01em;
    box-shadow: 0 12px 28px rgba(199, 161, 58, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .get-started-steps-v2__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 34px rgba(199, 161, 58, 0.26);
    opacity: 0.96;
  }

  @media screen and (max-width: 1100px) {
    .get-started-steps-v2__cards {
      grid-template-columns: repeat(2, minmax(280px, 1fr));
    }

    .get-started-step-card:last-child {
      grid-column: 1 / -1;
      max-width: 420px;
      margin: 0 auto;
    }

    .get-started-steps-v2__tagline {
      font-size: 26px;
    }

    .get-started-steps-v2__heading {
      font-size: 30px;
      margin-bottom: 54px;
    }
  }

  @media screen and (max-width: 749px) {
    .get-started-steps-v2 {
      padding: 64px 0 82px;
    }

    .get-started-steps-v2__wrapper {
      padding: 0 20px;
    }

    .get-started-steps-v2__topline {
      gap: 12px;
      margin-bottom: 14px;
    }

    .get-started-steps-v2__flame img {
      width: 52px;
    }

    .get-started-steps-v2__tagline {
      font-size: 22px;
    }

    .get-started-steps-v2__heading {
      font-size: 26px;
      margin-bottom: 38px;
    }

    .get-started-steps-v2__cards {
      grid-template-columns: 1fr;
      gap: 22px;
      margin-bottom: 42px;
    }

    .get-started-step-card,
    .get-started-step-card:last-child {
      max-width: 100%;
      min-height: auto;
      margin: 0;
      padding: 30px 22px 26px;
    }

    .get-started-step-card__title {
      font-size: 20px;
    }

    .get-started-step-card__description p {
      font-size: 15px;
      max-width: 100%;
    }

    .get-started-steps-v2__button {
      min-width: 220px;
      width: 100%;
      max-width: 320px;
      font-size: 18px;
      padding: 16px 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Get Started Steps V2",
  "settings": [
    {
      "type": "image_picker",
      "id": "top_icon",
      "label": "Top Flame Icon"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Top Tagline",
      "default": "Flare brings the spark back to dating"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Get Started In 3 Easy Steps"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Bottom Button Text",
      "default": "Get Started Today"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Bottom Button Link"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Step Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Fill Out the Intake Form"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Tell us a bit about yourself so we can match you with the right event and people."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Get Started Steps V2",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}
{% endschema %}

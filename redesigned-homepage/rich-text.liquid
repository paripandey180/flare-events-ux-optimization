{% comment %}
  Shopify Section: Featured In Logo Bar
  Save as: sections/featured-in-logo-bar.liquid
{% endcomment %}

<section id="shopify-section-{{ section.id }}" class="featured-in-bar">
  <div class="featured-in-bar__container">
    {% if section.settings.heading != blank %}
      <h2 class="featured-in-bar__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="featured-in-bar__logos" role="list" aria-label="Featured in logos">
      {% for block in section.blocks %}
        <div class="featured-in-bar__logo-item" role="listitem" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="featured-in-bar__logo-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
              {% if block.settings.logo != blank %}
                {{ block.settings.logo | image_url: width: 500 | image_tag:
                  class: 'featured-in-bar__logo-image',
                  loading: 'lazy',
                  widths: '120, 180, 240, 320, 500',
                  alt: block.settings.alt_text | default: block.settings.name
                }}
              {% else %}
                <span class="featured-in-bar__logo-text">{{ block.settings.name }}</span>
              {% endif %}
            </a>
          {% else %}
            {% if block.settings.logo != blank %}
              {{ block.settings.logo | image_url: width: 500 | image_tag:
                class: 'featured-in-bar__logo-image',
                loading: 'lazy',
                widths: '120, 180, 240, 320, 500',
                alt: block.settings.alt_text | default: block.settings.name
              }}
            {% else %}
              <span class="featured-in-bar__logo-text">{{ block.settings.name }}</span>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  <style>
    #shopify-section-{{ section.id }} {
      background: {{ section.settings.background_color }};
      color: {{ section.settings.text_color }};
    }

    #shopify-section-{{ section.id }} .featured-in-bar__container {
      max-width: 1600px;
      margin: 0 auto;
      padding: 24px 20px 40px;
    }

    #shopify-section-{{ section.id }} .featured-in-bar__heading {
      margin: 0 0 22px;
      text-align: center;
      color: {{ section.settings.text_color }};
      font-size: clamp(22px, 2vw, 34px);
      line-height: 1.2;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    #shopify-section-{{ section.id }} .featured-in-bar__logos {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: nowrap;
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .featured-in-bar__logo-item {
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1 1 0;
      min-width: 0;
      height: {{ section.settings.logo_max_height }}px;
    }

    #shopify-section-{{ section.id }} .featured-in-bar__logo-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      width: 100%;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .featured-in-bar__logo-image {
      display: block;
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
    }

    #shopify-section-{{ section.id }} .featured-in-bar__logo-text {
      color: {{ section.settings.text_color }};
      font-size: 22px;
      font-weight: 700;
      line-height: 1.1;
      white-space: nowrap;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} .featured-in-bar__container {
        padding: 20px 16px 32px;
      }

      #shopify-section-{{ section.id }} .featured-in-bar__logos {
        gap: 16px;
      }

      #shopify-section-{{ section.id }} .featured-in-bar__logo-item {
        height: {{ section.settings.logo_max_height_mobile }}px;
      }
    }

    @media screen and (max-width: 640px) {
      #shopify-section-{{ section.id }} .featured-in-bar__heading {
        margin-bottom: 18px;
      }

      #shopify-section-{{ section.id }} .featured-in-bar__logos {
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
      }

      #shopify-section-{{ section.id }} .featured-in-bar__logo-item {
        flex: 0 0 calc(33.333% - 14px);
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Featured in logo bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Proudly Featured In :"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Logo max height desktop",
      "min": 20,
      "max": 140,
      "step": 2,
      "default": 96
    },
    {
      "type": "range",
      "id": "logo_max_height_mobile",
      "label": "Logo max height mobile",
      "min": 20,
      "max": 100,
      "step": 2,
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Publication name"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": true
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Featured in logo bar",
      "blocks": [
        { "type": "logo", "settings": { "name": "Global News" } },
        { "type": "logo", "settings": { "name": "Toronto Star" } },
        { "type": "logo", "settings": { "name": "Toronto Life" } },
        { "type": "logo", "settings": { "name": "blogTO" } },
        { "type": "logo", "settings": { "name": "The Globe and Mail" } },
        { "type": "logo", "settings": { "name": "DatingNews" } },
        { "type": "logo", "settings": { "name": "DatingAdvice.com" } }
      ]
    }
  ]
}
{% endschema %}
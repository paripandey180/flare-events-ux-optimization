{% comment %} Added by Sanika {% endcomment %}

<section class="custom-section singles-events-section" id="events" itemscope itemtype="https://schema.org/EventSeries" aria-labelledby="events-heading">
  <div class="custom-section-container">

    <h1 class="custom-section-main-title rich-text__heading rte inline-richtext h1" id="events-heading" itemprop="name">
      Find Events In Your City
    </h1>

    <div class="custom-section-description body-text" itemprop="description">
      <p>
        Flare’s in-person speed dating events are designed for real connection.
        Enjoy hosted games, relaxed conversation, and meet new matches every
        eight minutes — then wait for our team to share your results.
      </p>
    </div>

    <div class="find-events-top-button">
      <a href="/pages/all-events" class="browse-events-btn">Browse ALL Events!</a>
    </div>
  </div>

  <div class="custom-section-container">
    <h2 class="sr-only">Available Cities for Singles Events</h2>
    <div class="cities-grid" role="list">
      {% assign cities = 'Toronto,Ottawa,Montréal,Québec City,Winnipeg,Calgary,Edmonton,Vancouver' | split: ',' %}
      {% assign city_links = 'https://flareevents.ca/toronto/#events,https://flareevents.ca/ottawa/#events,https://flareevents.ca/montreal/#events,https://flareevents.ca/quebec_city/#events,https://flareevents.ca/winnipeg/#events,https://flareevents.ca/calgary/#events,https://flareevents.ca/edmonton/#events,https://flareevents.ca/vancouver/#events' | split: ',' %}
      {% assign city_images = 'https://flareevents.store/cdn/shop/files/events_toronto.jpg,https://flareevents.store/cdn/shop/files/events_ottawa.jpg,https://flareevents.store/cdn/shop/files/events_montreal.jpg,https://flareevents.store/cdn/shop/files/events_quebec.jpg,https://flareevents.store/cdn/shop/files/events_winnipeg.jpg,https://flareevents.store/cdn/shop/files/events_calgary.jpg,https://flareevents.store/cdn/shop/files/events_edmonton.jpg,https://flareevents.store/cdn/shop/files/events_vancouver.jpg' | split: ',' %}
    
      {% for city in cities %}
        {% assign index = forloop.index0 %}
        <div class="city-grid-item">
          <a href="{{ city_links[index] }}" class="city-link-wrapper" role="listitem" aria-label="View singles events in {{ city }}">
            <div class="city-card" itemscope itemtype="https://schema.org/Place">
              <div class="city-image">
                <img
                  src="{{ city_images[index] }}"
                  alt="{{ city }} Events"
                  loading="lazy"
                  width="600"
                  height="520"
                >
              </div>
              <div class="city-content">
                <h2 class="city-name">{{ city }}</h2>
                <p class="city-link">
                  See Events
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                    <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </p>
              </div>
            </div>
          </a>

          {% if city == 'Vancouver' %}
            <div class="notify-under-card">
              <p class="notify-text">
                Don’t see events in your city?<br>
                Get notified when the next one launches
              </p>
              <a href="/pages/notify-me" class="notify-btn">Notify Me!</a>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="request-city-centered">
      <p class="request-city-text">Don’t see your city? Don’t worry, we’re expanding!</p>
      <a href="/pages/request-a-city" class="request-city-btn">Request A City</a>
    </div>
  </div>
</section>

<style>
.singles-events-section .custom-section-container {
  max-width: 1440px;
  margin: 0 auto;
  padding-left: 24px;
  padding-right: 24px;
}

.custom-section-main-title {
  text-align: center;
  color: #B59439;
  margin: 0 0 1.5rem 0;
  padding-top: 5rem;
}

.custom-section-description {
  max-width: 760px;
  margin: 0 auto 2rem auto;
  text-align: center;
}

.custom-section-description p {
  color: #ffffff;
  font-size: 1.35rem;
  line-height: 1.7;
  margin: 0;
}

.find-events-top-button {
  display: flex;
  justify-content: center;
  margin-bottom: 2.5rem;
}

.browse-events-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #d4af37;
  color: #000000;
  text-decoration: none;
  font-weight: 600;
  font-size: 1.25rem;
  padding: 0.9rem 2rem;
  border-radius: 999px;
  transition: all 0.25s ease;
}

.browse-events-btn:hover {
  opacity: 0.92;
  transform: translateY(-1px);
}

.cities-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 2rem;
  margin-top: 2rem;
  align-items: start;
}

.city-grid-item {
  display: block;
  position: relative;
}

.city-link-wrapper {
  text-decoration: none;
  display: block;
}

.city-card {
  width: 100%;
  background: #191919;
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  position: relative;
  cursor: pointer;
  text-align: center;
}

.city-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(212, 175, 55, 0.3);
  border: 1px solid #d4af37;
}

.city-image {
  height: 260px;
  overflow: hidden;
  position: relative;
}

.city-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
  display: block;
}

.city-card:hover .city-image img {
  transform: scale(1.05);
}

.city-content {
  padding: 0rem 2rem 2rem 2rem;
  position: relative;
  text-align: left;
}

.city-name {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 0rem;
  color: #ffffff;
  text-align: left;
}

.city-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #d4af37;
  text-decoration: none;
  font-weight: 400;
  font-size: 1.4rem;
  position: relative;
  text-align: left;
}

.notify-under-card {
  position: absolute;
  top: calc(100% + 12px);
  left: 50%;
  transform: translateX(-50%);
  width: 240px;
  max-width: 85%;
  text-align: center;
  z-index: 2;
}

.request-city-centered {
  text-align: center;
  margin-top: 5rem;
}

.request-city-text {
  color: #ffffff;
  font-size: 1.05rem;
  line-height: 1.45;
  margin-bottom: 0.8rem;
}

.notify-text {
  color: #ffffff;
  font-size: 0.92rem;
  line-height: 1.35;
  margin-bottom: 0.65rem;
  opacity: 0.9;
}

.request-city-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 260px;
  padding: 1rem 2rem;
  border: 2px solid #d4af37;
  border-radius: 999px;
  color: #ffffff;
  text-decoration: none;
  font-weight: 500;
  font-size: 1.3rem;
  background: transparent;
  transition: all 0.25s ease;
}

.request-city-btn:hover {
  background: rgba(212, 175, 55, 0.08);
}

.notify-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 170px;
  padding: 0.65rem 1.25rem;
  border-radius: 999px;
  background: #d4af37;
  color: #000000;
  text-decoration: none;
  font-weight: 600;
  font-size: 1rem;
  transition: all 0.25s ease;
}

.notify-btn:hover {
  opacity: 0.92;
}

@media (max-width: 1200px) {
  .cities-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .city-content {
    padding: 0rem 1.25rem 1.5rem 1.25rem;
  }

  .city-name {
    font-size: 1.7rem;
  }

  .city-link {
    font-size: 1.2rem;
  }
}

@media (max-width: 900px) {
  .cities-grid {
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .notify-under-card {
    position: static;
    transform: none;
    width: 100%;
    max-width: 100%;
    margin-top: 1rem;
  }

  .request-city-centered {
    margin-top: 2.5rem;
  }
}

@media (max-width: 480px) {
  .cities-grid {
    grid-template-columns: 1fr;
  }

  .custom-section-main-title {
    padding-top: 2.5rem;
  }

  .custom-section-description p {
    font-size: 1.05rem;
  }

  .browse-events-btn,
  .request-city-btn,
  .notify-btn {
    width: 100%;
    max-width: 320px;
  }
}
</style>

{% schema %}
{
  "name": "Homepage Events Section",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Homepage Events Section"
    }
  ]
}
{% endschema %}
